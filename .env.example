# MailMind local development environment template.
#
# This file may contain example values only. Do not put real tokens, API keys,
# OAuth secrets, or a real APP_ENCRYPTION_KEY in .env.example.
# Real local configuration belongs in .env, and .env must stay ignored by Git.

APP_ENV=development
APP_HOST=127.0.0.1
APP_PORT=8000

APP_SECRET_KEY=change-me
APP_ENCRYPTION_KEY=change-me-32-byte-base64
APP_ENCRYPTION_KEY_VERSION=v1

DATABASE_URL=postgresql+psycopg://mailmind:mailmind@localhost:5432/mailmind
REDIS_URL=redis://localhost:6379/0

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/auth/gmail/callback

LLM_PROVIDER=
LLM_API_KEY=
LLM_MODEL=

DEFAULT_TIMEZONE=Asia/Shanghai

DIGEST_AUTO_GENERATE=true
DIGEST_GENERATE_TIME=08:00

POSTGRES_DB=mailmind
POSTGRES_USER=mailmind
POSTGRES_PASSWORD=mailmind
